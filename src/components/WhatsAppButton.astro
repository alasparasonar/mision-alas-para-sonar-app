---
import site from '@data/site.json';

const number = import.meta.env.PUBLIC_WHATSAPP_NUMBER || site.whatsapp;
const text = encodeURIComponent('Hola, quiero recibir informacion sobre Fundación Misión Alas para Soñar.');
---

<a
  href={`https://wa.me/${number}?text=${text}`}
  class="fixed bottom-5 right-5 z-50 inline-flex items-center gap-3 rounded-full bg-[#25d366] px-4 py-3 text-white shadow-2xl shadow-[#25d366]/35 ring-4 ring-white/90 transition hover:-translate-y-1 hover:bg-[#1ebe5d] focus-visible:outline-[#25d366]"
  target="_blank"
  rel="noreferrer"
  aria-label="Escribir por WhatsApp"
>
  <span class="relative flex h-11 w-11 items-center justify-center rounded-full bg-white text-[#25d366]">
    <svg viewBox="0 0 32 32" class="h-7 w-7" aria-hidden="true">
      <path fill="currentColor" d="M16.02 3.2A12.73 12.73 0 0 0 5.17 22.57L3.8 28.8l6.37-1.54A12.74 12.74 0 1 0 16.02 3.2Zm0 22.96c-1.96 0-3.86-.56-5.5-1.62l-.39-.25-3.78.91.8-3.7-.26-.38a10.23 10.23 0 1 1 9.13 5.04Zm5.67-7.66c-.31-.16-1.85-.91-2.14-1.02-.29-.1-.5-.16-.71.16-.21.31-.82 1.01-1 1.22-.19.21-.37.23-.68.08-.31-.16-1.31-.48-2.49-1.54-.92-.82-1.54-1.83-1.72-2.14-.18-.31-.02-.48.14-.64.14-.14.31-.37.47-.55.16-.18.21-.31.31-.52.1-.21.05-.39-.03-.55-.08-.16-.71-1.71-.97-2.34-.26-.61-.52-.53-.71-.54h-.6c-.21 0-.55.08-.84.39-.29.31-1.1 1.08-1.1 2.63s1.13 3.05 1.29 3.26c.16.21 2.23 3.4 5.4 4.77.75.32 1.34.51 1.8.66.76.24 1.45.21 1.99.13.61-.09 1.85-.76 2.11-1.49.26-.73.26-1.36.18-1.49-.08-.13-.29-.21-.6-.36Z" />
    </svg>
    <span class="absolute -right-0.5 -top-0.5 h-3 w-3 rounded-full bg-sun ring-2 ring-white"></span>
  </span>
  <span class="hidden pr-1 text-left sm:block">
    <span class="block text-xs font-bold uppercase tracking-[0.16em] text-white/75">WhatsApp</span>
    <span class="block text-sm font-extrabold leading-tight">Hablar ahora</span>
  </span>
</a>
