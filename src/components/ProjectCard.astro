---
import { CalendarDays, MapPinned } from '@lucide/astro';

interface Props {
  project: any;
}

const { project } = Astro.props;
const data = project.data;
---

<article class="group overflow-hidden rounded-3xl bg-white shadow-xl shadow-sky-deep/10 ring-1 ring-sky-deep/10 transition hover:-translate-y-1 hover:shadow-2xl">
  <a href={`/proyectos/${project.id}/`} class="block">
    <img src={data.image} alt={`Imagen del proyecto ${data.title}`} class="aspect-[16/10] w-full object-cover transition duration-500 group-hover:scale-105" loading="lazy" />
    <div class="p-6">
      <div class="mb-4 flex flex-wrap gap-2 text-xs font-bold uppercase tracking-[0.12em] text-sky-deep">
        <span class="rounded-full bg-sky-bright/10 px-3 py-1">{data.status}</span>
        <span class="rounded-full bg-sun/30 px-3 py-1 text-ink">{data.impact}</span>
      </div>
      <h3 class="font-display text-2xl font-bold text-ink">{data.title}</h3>
      <p class="mt-3 line-clamp-3 text-sm leading-7 text-ink/68">{data.description}</p>
      <div class="mt-5 grid gap-2 text-sm text-ink/62">
        <p class="flex items-center gap-2"><CalendarDays size={16} /> {data.date.toLocaleDateString('es-EC')}</p>
        <p class="flex items-center gap-2"><MapPinned size={16} /> {data.place}</p>
      </div>
    </div>
  </a>
</article>
