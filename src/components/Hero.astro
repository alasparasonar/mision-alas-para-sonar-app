---
import { HeartHandshake, Sparkles, UsersRound, ShieldCheck } from '@lucide/astro';
import site from '@data/site.json';

const slides = [
  {
    title: 'Apoyo a la niñez',
    text: 'Espacios de cuidado, juego y aprendizaje para que cada niño se sienta visto y acompañado.',
    image: 'https://images.unsplash.com/photo-1503454537195-1dcabb73ffb9?auto=format&fit=crop&w=1500&q=85',
    alt: 'Niños participando en una actividad educativa',
    badge: 'Niñez',
  },
  {
    title: 'Familias acompañadas',
    text: 'Jornadas comunitarias con alimentos, escucha y orientación para responder a necesidades reales.',
    image: 'https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?auto=format&fit=crop&w=1500&q=85',
    alt: 'Voluntarios acompañando a familias en una actividad comunitaria',
    badge: 'Comunidad',
  },
  {
    title: 'Voluntariado con propósito',
    text: 'Personas que donan tiempo, talento y energía para convertir la solidaridad en acción.',
    image: 'https://images.unsplash.com/photo-1559027615-cd4628902d4a?auto=format&fit=crop&w=1500&q=85',
    alt: 'Voluntarios reunidos durante una jornada social',
    badge: 'Voluntariado',
  },
  {
    title: 'Donaciones transparentes',
    text: 'Cada aporte se organiza para llegar con respeto, dignidad y seguimiento a quienes más lo necesitan.',
    image: 'https://images.unsplash.com/photo-1469571486292-0ba58a3f068b?auto=format&fit=crop&w=1500&q=85',
    alt: 'Personas preparando ayuda solidaria para una comunidad',
    badge: 'Impacto',
  },
];
---

<section class="hero-stage wing-ribbon relative overflow-hidden bg-[radial-gradient(circle_at_14%_12%,rgba(255,209,42,0.26),transparent_24%),radial-gradient(circle_at_78%_18%,rgba(18,183,232,0.24),transparent_34%),linear-gradient(135deg,#f6fbff_0%,#ffffff_48%,#e4f7ff_100%)]">
  <div class="pointer-events-none absolute inset-0 opacity-70">
    <div class="hero-glow absolute -left-24 top-20 h-72 w-72 rounded-full bg-sun/30 blur-3xl"></div>
    <div class="hero-glow hero-glow-two absolute -right-20 bottom-24 h-80 w-80 rounded-full bg-sky-bright/25 blur-3xl"></div>
  </div>

  <div class="container-page grid min-h-[calc(100vh-80px)] items-center gap-10 py-12 lg:grid-cols-[0.9fr_1.1fr] lg:py-16">
    <div class="reveal relative z-10">
      <p class="mb-5 inline-flex items-center gap-2 rounded-full border border-sky-deep/15 bg-white/90 px-4 py-2 text-sm font-bold text-sky-deep shadow-sm">
        <HeartHandshake size={17} /> {site.tagline}
      </p>
      <h1 class="font-display text-5xl font-bold leading-[0.96] tracking-tight text-ink text-balance md:text-7xl">
        Alas que cuidan, sueños que vuelven a levantarse.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-ink/72 md:text-xl">
        Acompañamos a niños, familias y comunidades vulnerables con programas solidarios, voluntariado y proyectos que transforman la ayuda en esperanza concreta.
      </p>

      <div class="mt-8 grid gap-3 sm:grid-cols-3">
        <div class="rounded-2xl bg-white/80 p-4 shadow-lg shadow-sky-deep/10 ring-1 ring-sky-deep/10">
          <Sparkles class="text-sun" size={22} />
          <p class="mt-2 text-sm font-extrabold text-ink">Esperanza activa</p>
        </div>
        <div class="rounded-2xl bg-white/80 p-4 shadow-lg shadow-sky-deep/10 ring-1 ring-sky-deep/10">
          <UsersRound class="text-sky-deep" size={22} />
          <p class="mt-2 text-sm font-extrabold text-ink">Comunidad unida</p>
        </div>
        <div class="rounded-2xl bg-white/80 p-4 shadow-lg shadow-sky-deep/10 ring-1 ring-sky-deep/10">
          <ShieldCheck class="text-leaf" size={22} />
          <p class="mt-2 text-sm font-extrabold text-ink">Ayuda transparente</p>
        </div>
      </div>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a href="/quienes-somos/" class="rounded-full bg-sky-deep px-7 py-4 text-center font-extrabold text-white shadow-xl shadow-sky-deep/20 transition hover:-translate-y-0.5">Conócenos</a>
        <a href="/donaciones/" class="rounded-full bg-sun px-7 py-4 text-center font-extrabold text-ink shadow-xl shadow-sun/20 transition hover:-translate-y-0.5">Haz una donación</a>
        <a href="/voluntariado/" class="rounded-full border border-sky-deep/20 bg-white px-7 py-4 text-center font-extrabold text-ink transition hover:-translate-y-0.5 hover:border-sky-deep">Sé voluntario</a>
      </div>
    </div>

    <div class="reveal relative z-10" style="animation-delay: 120ms">
      <div class="hero-carousel relative" data-carousel>
        <div class="relative aspect-[4/5] overflow-hidden rounded-[2rem] bg-ink shadow-2xl shadow-sky-deep/20 lg:aspect-[5/6]">
          <div class="absolute inset-0 z-10 bg-gradient-to-t from-ink/78 via-ink/18 to-transparent"></div>
          {slides.map((slide, index) => (
            <img
              src={slide.image}
              alt={slide.alt}
              class:list={[
                'carousel-slide absolute inset-0 h-full w-full object-cover transition duration-700 ease-out',
                index === 0 ? 'is-active' : '',
              ]}
              data-slide
              loading={index === 0 ? 'eager' : 'lazy'}
            />
          ))}

          <div class="absolute inset-x-0 bottom-0 z-20 p-5 md:p-7">
            <p class="mb-3 inline-flex rounded-full bg-sun px-3 py-1 text-xs font-extrabold uppercase tracking-[0.16em] text-ink" data-caption-badge>{slides[0].badge}</p>
            <h2 class="font-display text-3xl font-bold leading-tight text-white md:text-4xl" data-caption-title>{slides[0].title}</h2>
            <p class="mt-3 max-w-md text-sm leading-7 text-white/82 md:text-base" data-caption-text>{slides[0].text}</p>
            <div class="mt-5 h-1.5 overflow-hidden rounded-full bg-white/25">
              <span class="carousel-progress block h-full rounded-full bg-sun" data-progress></span>
            </div>
          </div>
        </div>

        <div class="mt-4 grid grid-cols-[auto_1fr_auto] items-center gap-3">
          <button class="h-11 rounded-full border border-sky-deep/15 bg-white px-4 text-sm font-extrabold text-ink shadow-sm transition hover:border-sky-deep" type="button" data-prev aria-label="Imagen anterior">Anterior</button>
          <div class="flex justify-center gap-2" aria-label="Controles del carrusel">
            {slides.map((slide, index) => (
              <button
                class:list={[
                  'h-2.5 rounded-full bg-sky-deep/24 transition-all',
                  index === 0 ? 'w-8 bg-sky-deep' : 'w-2.5',
                ]}
                type="button"
                data-dot={index}
                aria-label={`Ver slide ${index + 1}: ${slide.title}`}
                aria-current={index === 0 ? 'true' : 'false'}
              ></button>
            ))}
          </div>
          <button class="h-11 rounded-full border border-sky-deep/15 bg-white px-4 text-sm font-extrabold text-ink shadow-sm transition hover:border-sky-deep" type="button" data-next aria-label="Imagen siguiente">Siguiente</button>
        </div>

        <div class="mt-4 grid gap-3 sm:grid-cols-4">
          {slides.map((slide, index) => (
            <button
              class:list={[
                'carousel-thumb rounded-2xl border bg-white p-2 text-left shadow-sm transition hover:-translate-y-0.5',
                index === 0 ? 'is-active border-sky-deep' : 'border-sky-deep/10',
              ]}
              type="button"
              data-thumb={index}
            >
              <img src={slide.image} alt="" class="aspect-[5/3] w-full rounded-xl object-cover" loading="lazy" />
              <span class="mt-2 block text-xs font-extrabold text-ink">{slide.badge}</span>
            </button>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline type="application/json" id="hero-slides" set:html={JSON.stringify(slides)}></script>

<script is:inline>
  const carousel = document.querySelector('[data-carousel]');
  const slidesData = JSON.parse(document.querySelector('#hero-slides')?.textContent || '[]');

  if (carousel) {
    const slideEls = [...carousel.querySelectorAll('[data-slide]')];
    const dotEls = [...carousel.querySelectorAll('[data-dot]')];
    const thumbEls = [...carousel.querySelectorAll('[data-thumb]')];
    const prev = carousel.querySelector('[data-prev]');
    const next = carousel.querySelector('[data-next]');
    const badge = carousel.querySelector('[data-caption-badge]');
    const title = carousel.querySelector('[data-caption-title]');
    const text = carousel.querySelector('[data-caption-text]');
    const progress = carousel.querySelector('[data-progress]');
    let current = 0;
    let timer;

    const restartProgress = () => {
      if (!progress) return;
      progress.classList.remove('is-running');
      void progress.offsetWidth;
      progress.classList.add('is-running');
    };

    const show = (index, resetTimer = false) => {
      current = (index + slidesData.length) % slidesData.length;
      slideEls.forEach((slide, slideIndex) => {
        slide.classList.toggle('is-active', slideIndex === current);
      });
      dotEls.forEach((dot, dotIndex) => {
        dot.classList.toggle('w-8', dotIndex === current);
        dot.classList.toggle('w-2.5', dotIndex !== current);
        dot.classList.toggle('bg-sky-deep', dotIndex === current);
        dot.classList.toggle('bg-sky-deep/24', dotIndex !== current);
        dot.setAttribute('aria-current', dotIndex === current ? 'true' : 'false');
      });
      thumbEls.forEach((thumb, thumbIndex) => {
        thumb.classList.toggle('is-active', thumbIndex === current);
        thumb.classList.toggle('border-sky-deep', thumbIndex === current);
        thumb.classList.toggle('border-sky-deep/10', thumbIndex !== current);
      });
      badge.textContent = slidesData[current].badge;
      title.textContent = slidesData[current].title;
      text.textContent = slidesData[current].text;
      restartProgress();
      if (resetTimer) start();
    };

    const start = () => {
      stop();
      timer = window.setInterval(() => show(current + 1), 5200);
    };

    const stop = () => {
      if (timer) window.clearInterval(timer);
    };

    prev?.addEventListener('click', () => show(current - 1, true));
    next?.addEventListener('click', () => show(current + 1, true));
    dotEls.forEach((dot) => dot.addEventListener('click', () => show(Number(dot.dataset.dot), true)));
    thumbEls.forEach((thumb) => thumb.addEventListener('click', () => show(Number(thumb.dataset.thumb), true)));

    restartProgress();
    start();
  }
</script>
