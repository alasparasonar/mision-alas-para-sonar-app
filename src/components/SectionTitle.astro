---
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, text, align = 'left' } = Astro.props;
---

<div class:list={['max-w-3xl', align === 'center' ? 'mx-auto text-center' : '']}>
  {eyebrow && <p class="mb-3 text-sm font-extrabold uppercase tracking-[0.22em] text-sky-deep">{eyebrow}</p>}
  <h2 class="font-display text-4xl font-bold leading-tight text-ink text-balance md:text-5xl">{title}</h2>
  {text && <p class="mt-5 text-lg leading-8 text-ink/70">{text}</p>}
</div>
