---
import site from '@data/site.json';

const endpoint = import.meta.env.PUBLIC_CONTACT_FORM_ENDPOINT || '';
---

<form class="grid gap-4 rounded-3xl bg-white p-6 shadow-xl shadow-sky-deep/10 ring-1 ring-sky-deep/10" action={endpoint || `mailto:${site.email}`} method="POST">
  <input type="hidden" name="form_type" value="contacto" />
  <div>
    <label class="mb-2 block text-sm font-bold text-ink" for="name">Nombre</label>
    <input class="w-full rounded-2xl border border-sky-deep/15 px-4 py-3" id="name" name="name" autocomplete="name" required />
  </div>
  <div>
    <label class="mb-2 block text-sm font-bold text-ink" for="email">Correo</label>
    <input class="w-full rounded-2xl border border-sky-deep/15 px-4 py-3" id="email" type="email" name="email" autocomplete="email" required />
  </div>
  <div>
    <label class="mb-2 block text-sm font-bold text-ink" for="subject">Asunto</label>
    <input class="w-full rounded-2xl border border-sky-deep/15 px-4 py-3" id="subject" name="subject" required />
  </div>
  <div>
    <label class="mb-2 block text-sm font-bold text-ink" for="message">Mensaje</label>
    <textarea class="min-h-36 w-full rounded-2xl border border-sky-deep/15 px-4 py-3" id="message" name="message" required></textarea>
  </div>
  <button class="rounded-full bg-sky-deep px-6 py-4 font-extrabold text-white" type="submit">Enviar mensaje</button>
  <p class="text-xs leading-6 text-ink/55">Configura PUBLIC_CONTACT_FORM_ENDPOINT con Formspree, Resend, Cloudflare Workers u otro servicio para envio real.</p>
</form>
