---
import { BadgeCheck, CircleAlert, Send } from '@lucide/astro';
import site from '@data/site.json';

const endpoint = import.meta.env.PUBLIC_CONTACT_FORM_ENDPOINT || 'https://formspree.io/f/meewvpbp';
const formId = endpoint.split('/').filter(Boolean).pop() ?? '';
const formElementId = 'contact-form';
---

<div class="formspree-shell rounded-[2rem] bg-white p-6 shadow-xl shadow-sky-deep/10 ring-1 ring-sky-deep/10 md:p-7">
  <div data-fs-success class="formspree-banner formspree-banner-success">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start">
      <span class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-leaf/12 text-leaf">
        <BadgeCheck size={28} />
      </span>
      <div>
        <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-leaf">Mensaje enviado</p>
        <h3 class="mt-2 font-display text-3xl font-bold text-ink">Gracias por escribirnos.</h3>
        <p class="mt-3 max-w-2xl text-sm leading-7 text-ink/70">
          Recibimos tu mensaje correctamente. La fundación podrá responderte desde el correo institucional o por los datos que nos compartiste.
        </p>
      </div>
    </div>
  </div>

  <div data-fs-error class="formspree-banner formspree-banner-error">
    <div class="flex items-start gap-3">
      <span class="mt-0.5 inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-coral/10 text-coral">
        <CircleAlert size={22} />
      </span>
      <div>
        <p class="font-bold text-coral">No pudimos enviar el mensaje.</p>
        <p class="mt-1 text-sm leading-6 text-ink/68">Revisa los campos e intenta nuevamente en unos segundos.</p>
      </div>
    </div>
  </div>

  <form id={formElementId} class="grid gap-4" action={endpoint || `mailto:${site.email}`} method="POST">
    <input type="hidden" name="form_type" value="contacto" />
    <input type="hidden" name="_subject" value="Nuevo mensaje desde el sitio web" />
    <div>
      <label class="mb-2 block text-sm font-bold text-ink" for="name">Nombre</label>
      <input class="w-full rounded-2xl border border-sky-deep/15 px-4 py-3" id="name" name="name" autocomplete="name" required data-fs-field />
      <span class="formspree-field-error" data-fs-error="name"></span>
    </div>
    <div>
      <label class="mb-2 block text-sm font-bold text-ink" for="email">Correo</label>
      <input class="w-full rounded-2xl border border-sky-deep/15 px-4 py-3" id="email" type="email" name="email" autocomplete="email" required data-fs-field />
      <span class="formspree-field-error" data-fs-error="email"></span>
    </div>
    <div>
      <label class="mb-2 block text-sm font-bold text-ink" for="subject">Asunto</label>
      <input class="w-full rounded-2xl border border-sky-deep/15 px-4 py-3" id="subject" name="subject" required data-fs-field />
      <span class="formspree-field-error" data-fs-error="subject"></span>
    </div>
    <div>
      <label class="mb-2 block text-sm font-bold text-ink" for="message">Mensaje</label>
      <textarea class="min-h-36 w-full rounded-2xl border border-sky-deep/15 px-4 py-3" id="message" name="message" required data-fs-field></textarea>
      <span class="formspree-field-error" data-fs-error="message"></span>
    </div>
    <button class="inline-flex items-center justify-center gap-2 rounded-full bg-sky-deep px-6 py-4 font-extrabold text-white" type="submit" data-fs-submit-btn>
      <Send size={18} />
      <span>Enviar mensaje</span>
    </button>
    <p class="text-xs leading-6 text-ink/55">Este formulario está conectado con Formspree y enviará los mensajes al correo configurado en ese servicio.</p>
  </form>
</div>

<script is:inline define:vars={{ formElementId, formId }}>
  window.formspree =
    window.formspree ||
    function () {
      (formspree.q = formspree.q || []).push(arguments);
    };

  if (formElementId && formId) {
    formspree('initForm', {
      formElement: `#${formElementId}`,
      formId,
    });
  }
</script>
<script is:inline src="https://unpkg.com/@formspree/ajax@1" defer></script>
