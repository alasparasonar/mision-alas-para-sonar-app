---
const stats = [
  { value: '+500', label: 'Beneficiarios proyectados' },
  { value: '36', label: 'Actividades solidarias' },
  { value: '+80', label: 'Voluntarios aliados' },
  { value: '12', label: 'Comunidades atendidas' },
];
---

<section class="-mt-8 relative z-20">
  <div class="container-page grid gap-3 rounded-3xl border border-sky-deep/10 bg-white p-4 shadow-2xl shadow-sky-deep/10 sm:grid-cols-2 lg:grid-cols-4">
    {stats.map((stat) => (
      <div class="rounded-2xl bg-cloud p-6 text-center">
        <p class="font-display text-4xl font-bold text-sky-deep">{stat.value}</p>
        <p class="mt-2 text-sm font-semibold text-ink/68">{stat.label}</p>
      </div>
    ))}
  </div>
</section>
