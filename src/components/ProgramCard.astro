---
interface Props {
  program: {
    title: string;
    description: string;
    image: string;
  };
}

const { program } = Astro.props;
---

<article class="group overflow-hidden rounded-3xl bg-white shadow-xl shadow-sky-deep/10 ring-1 ring-sky-deep/10">
  <img src={program.image} alt={`Imagen de ${program.title}`} class="aspect-[4/3] w-full object-cover transition duration-500 group-hover:scale-105" loading="lazy" />
  <div class="p-6">
    <h3 class="font-display text-2xl font-bold text-ink">{program.title}</h3>
    <p class="mt-3 text-sm leading-7 text-ink/68">{program.description}</p>
  </div>
</article>
