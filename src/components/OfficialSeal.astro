---
import { BadgeCheck, HandHeart } from '@lucide/astro';
import site from '@data/site.json';
---

<section class="relative overflow-hidden bg-[linear-gradient(135deg,#087bb6_0%,#12b7e8_52%,#f6fbff_52%,#ffffff_100%)] py-16">
  <div class="container-page grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
    <div class="relative mx-auto w-full max-w-sm">
      <div class="absolute inset-0 rounded-full bg-sun/45 blur-3xl"></div>
      <div class="seal-orbit absolute inset-[-18px] rounded-full border border-dashed border-white/70"></div>
      <span class="seal-spark absolute left-8 top-5 h-3 w-3 rounded-full bg-sun shadow-lg shadow-sun/40"></span>
      <span class="seal-spark absolute bottom-14 right-2 h-2.5 w-2.5 rounded-full bg-coral shadow-lg shadow-coral/40"></span>
      <span class="seal-spark absolute right-12 top-0 h-2 w-2 rounded-full bg-white shadow-lg shadow-white/40"></span>
      <img
        src={site.logo}
        alt={`Logo oficial de ${site.legalName}`}
        class="relative aspect-square w-full rounded-full border-[10px] border-white object-cover shadow-2xl shadow-ink/20"
        loading="lazy"
      />
    </div>

    <div class="rounded-3xl bg-white/92 p-8 shadow-2xl shadow-ink/10 ring-1 ring-sky-deep/10 backdrop-blur md:p-10">
      <p class="mb-4 inline-flex items-center gap-2 rounded-full bg-sun px-4 py-2 text-sm font-extrabold text-ink">
        <BadgeCheck size={18} /> Sello institucional
      </p>
      <h2 class="font-display text-4xl font-bold leading-tight text-ink text-balance md:text-5xl">
        Fundación Misión Alas para Soñar, una identidad hecha para ayudar.
      </h2>
      <p class="mt-5 text-lg leading-8 text-ink/70">
        El logo representa el compromiso de tender alas a personas vulnerables: cuidado, acompañamiento, esperanza y una misión social que se construye con comunidad.
      </p>
      <div class="mt-7 grid gap-3 sm:grid-cols-2">
        <div class="rounded-2xl bg-cloud p-5">
          <HandHeart class="text-sky-deep" size={26} />
          <p class="mt-3 font-extrabold text-ink">Misión ayudar</p>
          <p class="mt-2 text-sm leading-6 text-ink/62">Acompañamiento humano y solidario.</p>
        </div>
        <div class="rounded-2xl bg-cloud p-5">
          <BadgeCheck class="text-leaf" size={26} />
          <p class="mt-3 font-extrabold text-ink">Confianza visual</p>
          <p class="mt-2 text-sm leading-6 text-ink/62">Una marca reconocible en cada canal.</p>
        </div>
      </div>
    </div>
  </div>
</section>
