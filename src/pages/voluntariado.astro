---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionTitle from '@components/SectionTitle.astro';
import VolunteerForm from '@components/VolunteerForm.astro';
---

<BaseLayout title="Voluntariado" description="Formulario de inscripcion para voluntarios de Fundacion Alas para Sonar.">
  <section class="section-pad bg-white">
    <div class="container-page grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <div>
        <SectionTitle eyebrow="Voluntariado" title="Tu tiempo puede convertirse en esperanza concreta." text="Completa el formulario para sumarte a actividades comunitarias, apoyo logistico, comunicacion, donaciones o acompanamiento." />
        <div class="mt-8 rounded-3xl bg-cloud p-6 text-sm leading-7 text-ink/70">
          La fundacion podra responder desde su correo institucional cuando conecte el servicio de envio de formularios.
        </div>
      </div>
      <VolunteerForm />
    </div>
  </section>
</BaseLayout>
