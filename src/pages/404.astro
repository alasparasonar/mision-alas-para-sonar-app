---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Pagina no encontrada" description="La pagina solicitada no existe.">
  <section class="section-pad min-h-[70vh] bg-white">
    <div class="container-page max-w-2xl text-center">
      <p class="font-display text-8xl font-bold text-sky-deep">404</p>
      <h1 class="mt-4 font-display text-4xl font-bold text-ink">Esta pagina no encontro sus alas.</h1>
      <p class="mt-4 text-lg leading-8 text-ink/70">Puede que el enlace haya cambiado o que el contenido aun no este publicado.</p>
      <a href="/" class="mt-8 inline-flex rounded-full bg-sun px-7 py-4 font-extrabold text-ink">Volver al inicio</a>
    </div>
  </section>
</BaseLayout>
