---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionTitle from '@components/SectionTitle.astro';
import about from '@data/about.json';
import { BadgeCheck, CalendarDays, FileCheck, Sparkles } from '@lucide/astro';
---

<BaseLayout title="Quiénes somos" description="Historia, misión, visión, valores y equipo de Fundación Misión Alas para Soñar.">
  <section class="section-pad bg-white">
    <div class="container-page grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <SectionTitle eyebrow="Quiénes somos" title="Una fundación para acompañar con dignidad." text={about.history} />
      <img src="https://images.unsplash.com/photo-1529156069898-49953e39b3ac?auto=format&fit=crop&w=1300&q=85" alt="Equipo de voluntarios reunido en una actividad social" class="rounded-3xl shadow-2xl shadow-sky-deep/15" />
    </div>
  </section>

  <section class="section-pad">
    <div class="container-page grid gap-6 md:grid-cols-2">
      <div class="rounded-3xl bg-white p-8 shadow-xl shadow-sky-deep/10 ring-1 ring-sky-deep/10">
        <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-sky-deep">Misión</p>
        <p class="mt-4 text-lg leading-8 text-ink/74">{about.mission}</p>
      </div>
      <div class="rounded-3xl bg-white p-8 shadow-xl shadow-sky-deep/10 ring-1 ring-sky-deep/10">
        <p class="text-sm font-extrabold uppercase tracking-[0.18em] text-sky-deep">Visión</p>
        <p class="mt-4 text-lg leading-8 text-ink/74">{about.vision}</p>
      </div>
    </div>
  </section>

  <section class="section-pad wing-ribbon">
    <div class="container-page">
      <div class="grid gap-8 lg:grid-cols-[0.72fr_1.28fr] lg:items-end">
        <SectionTitle
          eyebrow="Directiva registrada"
          title="Liderazgo institucional para servir con orden y transparencia."
          text="La fundación cuenta con una directiva registrada oficialmente para acompañar la gestión social, administrativa y comunitaria."
        />
        <div class="rounded-3xl bg-ink p-6 text-white shadow-2xl shadow-sky-deep/15">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <p class="inline-flex items-center gap-2 rounded-full bg-sun px-4 py-2 text-sm font-extrabold text-ink">
                <CalendarDays size={18} /> Periodo vigente
              </p>
              <p class="mt-4 font-display text-2xl font-bold">{about.board.period}</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/10 p-4 text-sm leading-6 text-white/74">
              <FileCheck class="mb-2 text-sun" size={24} />
              {about.board.source}
            </div>
          </div>
        </div>
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        {about.board.members.map((member, index) => (
          <article class="group relative overflow-hidden rounded-3xl bg-white p-6 shadow-xl shadow-sky-deep/10 ring-1 ring-sky-deep/10 transition hover:-translate-y-1">
            <span class="absolute -right-8 -top-8 h-24 w-24 rounded-full bg-sun/20 blur-2xl transition group-hover:scale-125"></span>
            <span class="relative inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-cloud text-sky-deep ring-1 ring-sky-deep/10">
              {index === 0 ? <BadgeCheck size={26} /> : <Sparkles size={24} />}
            </span>
            <p class="relative mt-6 text-sm font-extrabold uppercase tracking-[0.18em] text-sky-deep">{member.role}</p>
            <h3 class="relative mt-2 font-display text-2xl font-bold leading-tight text-ink">{member.name}</h3>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad bg-white">
    <div class="container-page">
      <SectionTitle eyebrow="Valores" title="La forma importa tanto como la ayuda." />
      <div class="mt-10 grid gap-5 md:grid-cols-4">
        {about.values.map((value) => (
          <article class="rounded-3xl bg-cloud p-6">
            <h3 class="font-display text-2xl font-bold text-ink">{value.name}</h3>
            <p class="mt-3 text-sm leading-7 text-ink/68">{value.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-page">
      <SectionTitle eyebrow="Equipo" title="Personas que sostienen la misión." text={about.message} />
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {about.team.map((member) => (
          <article class="rounded-3xl bg-white p-7 shadow-xl shadow-sky-deep/10 ring-1 ring-sky-deep/10">
            <h3 class="font-display text-2xl font-bold text-ink">{member.name}</h3>
            <p class="mt-2 text-sm font-extrabold uppercase tracking-[0.14em] text-sky-deep">{member.role}</p>
            <p class="mt-4 text-sm leading-7 text-ink/68">{member.bio}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
