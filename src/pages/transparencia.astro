---
import { FileText } from '@lucide/astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionTitle from '@components/SectionTitle.astro';
import documents from '@data/transparency.json';
---

<BaseLayout title="Transparencia" description="Documentos, informes y rendicion de cuentas de Fundacion Alas para Sonar.">
  <section class="section-pad bg-white">
    <div class="container-page">
      <SectionTitle eyebrow="Transparencia" title="Rendicion de cuentas y documentos institucionales." text="Espacio administrable para informes, certificados, memorias anuales y documentos oficiales." />
      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {documents.items.map((doc) => (
          <article class="rounded-3xl bg-cloud p-6 ring-1 ring-sky-deep/10">
            <FileText class="text-sky-deep" size={30} />
            <h3 class="mt-4 font-display text-2xl font-bold text-ink">{doc.title}</h3>
            <p class="mt-2 text-sm font-bold text-ink/56">{new Date(doc.date).toLocaleDateString('es-EC')}</p>
            <p class="mt-3 text-sm leading-7 text-ink/68">{doc.description}</p>
            <a href={doc.fileUrl} class="mt-5 inline-flex rounded-full bg-sky-deep px-5 py-3 text-sm font-extrabold text-white">Ver documento</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
