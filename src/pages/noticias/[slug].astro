---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('news');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.summary} image={post.data.image}>
  <article class="section-pad bg-white">
    <div class="container-page max-w-4xl">
      <a href="/noticias/" class="text-sm font-bold text-sky-deep">Volver a noticias</a>
      <p class="mt-5 text-sm font-extrabold uppercase tracking-[0.18em] text-sky-deep">{post.data.date.toLocaleDateString('es-EC')}</p>
      <h1 class="mt-4 font-display text-5xl font-bold leading-tight text-ink">{post.data.title}</h1>
      <p class="mt-5 text-xl leading-8 text-ink/70">{post.data.summary}</p>
      <img src={post.data.image} alt={`Imagen de ${post.data.title}`} class="mt-8 aspect-[16/9] w-full rounded-3xl object-cover shadow-2xl shadow-sky-deep/15" />
      <div class="prose prose-lg mt-10 max-w-none text-ink/78">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
