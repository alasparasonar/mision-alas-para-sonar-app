---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionTitle from '@components/SectionTitle.astro';
import DonationBox from '@components/DonationBox.astro';
---

<BaseLayout title="Donaciones" description="Formas de donar y apoyar a Fundacion Alas para Sonar.">
  <section class="section-pad bg-white">
    <div class="container-page">
      <SectionTitle eyebrow="Donaciones" title="Ayudar tambien es construir confianza." text="Esta pagina deja parametrizados los datos bancarios, enlaces externos, QR y mensaje de transparencia." />
      <div class="mt-10">
        <DonationBox />
      </div>
    </div>
  </section>
</BaseLayout>
