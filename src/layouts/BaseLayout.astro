---
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import SEOHead from '@components/SEOHead.astro';
import WhatsAppButton from '@components/WhatsAppButton.astro';
import '@styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  pathname?: string;
}

const { title, description, image, pathname } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEOHead title={title} description={description} image={image} pathname={pathname ?? Astro.url.pathname} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />
  </body>
</html>
